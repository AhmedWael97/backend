APP_NAME=EYE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── Frontend API Keys ────────────────────────────────────────────────────────
# Generate once with: php artisan app:generate-api-keys
# Copy both values to the frontend .env as API_PUBLIC_KEY and API_SECRET_KEY
APP_PUBLIC_KEY=
APP_SECRET_KEY=

# ─── Database (PostgreSQL via PgBouncer) ──────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=eye
DB_USERNAME=eye
DB_PASSWORD=secret

# ─── Database direct (for migrations — bypass PgBouncer) ─────────────────────
DB_DIRECT_HOST=postgresql
DB_DIRECT_PORT=5432

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=eye_analytics
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret
REDIS_CLIENT=predis

# ─── Cache & Session ─────────────────────────────────────────────────────────
CACHE_DRIVER=redis
CACHE_PREFIX=eye_
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ─── Broadcasting (Reverb) ────────────────────────────────────────────────────
BROADCAST_DRIVER=reverb
REVERB_APP_ID=eye-app
REVERB_APP_KEY=eye-key
REVERB_APP_SECRET=eye-secret
REVERB_HOST=laravel-reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Auth ────────────────────────────────────────────────────────────────────
EMAIL_VERIFICATION_ENABLED=false

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_SECRET=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_ENDPOINT=api.mailgun.net

# Postmark alternative:
# MAIL_MAILER=postmark
# POSTMARK_TOKEN=

# Amazon SES alternative:
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# SMTP fallback:
# MAIL_MAILER=smtp
# MAIL_HOST=mailhog
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── IP-to-Company Enrichment (B2B, Pro plan) ────────────────────────────────
IPINFO_TOKEN=

# ─── GeoLite2 (MaxMind) ──────────────────────────────────────────────────────
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=/var/www/backend/storage/geoip/GeoLite2-City.mmdb

# ─── Error Monitoring ────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1

# ─── Horizon ──────────────────────────────────────────────────────────────────
HORIZON_PATH=horizon

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── 2FA ─────────────────────────────────────────────────────────────────────
TOTP_ISSUER="${APP_NAME}"
